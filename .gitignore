# Dependencies
node_modules/
.pnpm/
.pnpm-store/

# Build output
dist/
build/
out/
**/target/

# Test / coverage artifacts
coverage/
*.profraw
*.profdata
*.lcov
# Single-file coverage outputs from `go test -coverprofile=` (regenerable)
**/coverage.out
# graphify cache outputs (regenerable; ~200k lines)
graphify-out/cache/
graphify-out/.graphify_detect.*
graphify-out/graph.html
graphify-out/graph.json
graphify-out/manifest.json
graphify-out/cost.json
# knowledge/ session notes (working memory, not source)
knowledge/

# Probe file used during scaffold-commit testing
_probe_commit_test.txt

# Logs
*.log

# OS / editor
.DS_Store
Thumbs.db
*.swp

# Raw k6 benchmark sample dumps (regenerable; ~82MB each).
# Keep the aggregates: *_summary.json, *_stats.json, *.log, aggregated.json.
*_run[0-9].json
*_run[0-9][0-9].json

# Tool caches
.opencode/tmp/
.opencode/node_modules/
.opencode/package-lock.json

# Agent-platform session state (added 2026-06-21 — see AGENTS.md § "Tooling root convention").
# These folders are produced by editor/CLI tools (OpenCode, Codex, Playwright MCP, omo)
# and should NOT be committed as source. .mavis/ remains the canonical derived view for
# the learner substrate; everything else is platform state.
.omo/boulder.json
.omo/drafts/
.omo/evidence/f3-*.png
.omo/evidence/f3-*.log
.omo/run-continuation/
.codex/napkin.md
.playwright-mcp/console-*.log
.playwright-mcp/page-*.yml
# Allow the curated, human-written evidence files to keep flowing through git:
!.omo/evidence/f*-code-quality.md
!.omo/evidence/f*-scope-fidelity.md
!.omo/evidence/f*-manual-qa.md
!.omo/evidence/task-*.txt
!.omo/notepads/
.mavis/plans/personas-agora-deliverable.tar.gz

# Python bytecode
__pycache__/
*.pyc
