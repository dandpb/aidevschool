    content: {fontSize: 10.5, color: "$ink", bold: true, letterSpacing: 1.2, align: [left, middle], wrap: false, text: "INVARIANTES IMPOSTAS POR validate()"}
  - elementId: inv-list
    elementType: text
    bounds: [516, 150, 388, 240]
    content:
      style: "$body"
      fontSize: 10.5
      align: [left, top]
      text: |
        <p>· <strong>retry_count ≤ retry_limit</strong> (3) — sem exceções;</p>
        <p style="margin-top:6px">· <strong>mastered exige review de gate</strong> — "mastery requires executable evidence, never docs alone";</p>
        <p style="margin-top:6px">· <strong>rating consistente com gate_outcome</strong> — o gate é o único produtor de rating (autoavaliação proibida);</p>
        <p style="margin-top:6px">· unidade mastered precisa de <strong>attempt_file existente e não-vazio</strong>;</p>
        <p style="margin-top:6px">· <strong>requires_attempt_before_solution: true</strong> — sempre;</p>
        <p style="margin-top:6px">· streak: 0 ≤ equipped ≤ max ≤ 2 (cap 2 é "load-bearing": 3 freezes não performam melhor);</p>
        <p style="margin-top:6px">· AIDI: 0 ≤ amber &lt; red ≤ 1, histórico com datas estritamente ascendentes.</p>
