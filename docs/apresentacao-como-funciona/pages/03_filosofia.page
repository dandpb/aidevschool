    content:
      style: "$body"
      fontSize: 11.5
      align: [left, top]
      text: |
        <p><strong>Produtor ≠ verificador</strong> — nada se autoverifica; o verificador trabalha de contexto isolado.</p>
  - elementId: r3-n
    elementType: text
    bounds: [56, 450, 30, 30]
