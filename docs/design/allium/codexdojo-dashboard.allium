-- allium: 3
-- codexdojo-dashboard.allium

-- Scope: user-facing codexDojo dashboard behaviour distilled from engines/codexDojo/src.
-- Includes: dashboard session state, view navigation, cycle advancement, agent prompt copy, roadmap filtering, honest metric status, ecosystem contract status.
-- Excludes: CSS/layout, Vite/browser mounting mechanics, DOM event delegation details, snapshot formatting.

------------------------------------------------------------
-- Given
------------------------------------------------------------

given {
    session: DashboardSession
}

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity LearnerSnapshot {
    active_unit: ActiveUnit
    gate: Gate
    profile: Profile
    aidi: Aidi
    top_pitfalls: List<TopPitfall>
    next_reviews: List<NextReview>
    mastered_count: Integer
    scaffolded_count: Integer
    streak: Streak
    curr: Decimal
}

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value ActiveUnit {
    id: String
    title: String
    project: String
    state: String
    retry_count: Integer
    retry_limit: Integer
}

value Gate {
    implementation_blocked: Boolean
    unblock_condition: String
}

value Profile {
    dreyfus: String
    bloom: String
    active_language: String
    weekly_time_hours: Integer
}

value Aidi {
    current: Decimal
    threshold_amber: Decimal
    threshold_red: Decimal
    trend: List<Decimal>
}

value TopPitfall {
    id: String
    description: String
    occurrences: Integer
    last_seen: String
}

value NextReview {
    unit_id: String
    title: String
    due_in: String
    reason: String
}

value Streak {
    current: Integer
    longest: Integer
    last_gate_date: String?
    freezes_equipped: Integer
    freezes_max: Integer
}

------------------------------------------------------------
-- Entities and Variants
------------------------------------------------------------

entity Agent {
    id: String
    name: String
    group: leader | pedagogia | qualidade | memoria | governanca
    role: String
    mission: String
    inputs: Set<String>
    outputs: Set<String>
    gate: String
    prompt: String
}

entity UserFacingAgent {
    id: String
    name: String
    responsibility: String
    expands_to: Set<String>
}

entity CycleStage {
    id: String
    label: String
    owner: String
    evidence: String
    output: String
}

entity DojoProject {
    id: String
    title: String
    phase: fundamentos | concorrencia | arquitetura | escalabilidade | resiliencia | sistemas_complexos
    level: Integer
    language: String
    architecture: String
    learning_goal: String
    evidence: Set<String>
    functional_requirements: Set<String>?
    non_functional_requirements: Set<String>?
    extra_done_criteria: Set<String>?
}

entity Metric {
    id: String
    label: String
    target: String
    signal: String
    measurement: String?
    evidence_path: String?

    is_measured: measurement != null
}

entity EcosystemStatus {
    id: String
    label: String
    state: String
    evidence: String
    next_step: String
}

entity DashboardSession {
    view: overview | agents | cycle | roadmap | project
    selected_agent: Agent
    selected_project: DojoProject
    selected_stage: CycleStage
    completed_stages: Set<CycleStage>
    project_filter: all | fundamentos | concorrencia | arquitetura | escalabilidade | resiliencia | sistemas_complexos
    copied_agent: Agent?
    learner_snapshot: LearnerSnapshot

    completion_percent: round((completed_stages.count * 100) / CycleStages.count)
}

rule DashboardStartsAtOverview {
    when: session: DashboardSession.created

    ensures: session.view = overview
    ensures: session.selected_agent = Agents.first
    ensures: session.selected_stage = CycleStages.first
    ensures: session.project_filter = all
    ensures: session.copied_agent = null
}

rule UserChangesView {
    when: UserChangesView(session, view)

    ensures: session.view = view
    ensures: session.copied_agent = null
}

rule UserSelectsAgent {
    when: UserSelectsAgent(session, agent)
    requires: agent in Agents

    ensures: session.selected_agent = agent
    ensures: session.view = agents
    ensures: session.copied_agent = null
}

rule UserSelectsCycleStage {
    when: UserSelectsCycleStage(session, stage)
    requires: stage in CycleStages

    ensures: session.selected_stage = stage
    ensures: session.view = cycle
}

rule UserAdvancesCycleStage {
    when: UserAdvancesCycleStage(session)
    let previous = session.selected_stage
    let next = CycleStages.after(previous) ?? CycleStages.first

    ensures: session.selected_stage = next
    ensures: session.completed_stages = session.completed_stages + { previous }
    ensures: session.view = cycle
}

rule UserFiltersRoadmap {
    when: UserFiltersRoadmap(session, filter)

    ensures: session.project_filter = filter
    ensures: session.view = roadmap
}

rule UserSelectsProject {
    when: UserSelectsProject(session, project)
    requires: project in DojoProjects

    ensures: session.selected_project = project
    ensures: session.view = project
}

rule UserCopiesAgentPrompt {
    when: UserCopiesAgentPrompt(session, agent)
    requires: agent in Agents

    ensures: session.copied_agent = agent
}

rule AgentPromptCopyFails {
    when: AgentPromptCopyFails(session, agent)
    requires: session.copied_agent = agent

    ensures: session.copied_agent = null
}

surface OverviewDashboard {
    facing viewer: DashboardSession

    context session: DashboardSession

    exposes:
        session.completion_percent
        Agents.count
        CycleStages.count
        DojoProjects.count
        for agent in UserFacingAgents:
            agent.name
        DojoProjects.first.title
        DojoProjects.first.learning_goal
        for metric in Metrics:
            metric.label
            metric.measurement
            metric.target
            metric.signal
            metric.evidence_path
        for status in EcosystemStatuses:
            status.label
            status.state
            status.evidence
            status.next_step
        for stage in CycleStages.first(6):
            stage.owner
            stage.label

    provides:
        UserChangesView(session, cycle)
        UserChangesView(session, agents)
        UserSelectsAgent(session, agent)
        UserSelectsCycleStage(session, stage)
}

surface AgentsDashboard {
    facing viewer: DashboardSession

    context session: DashboardSession

    exposes:
        for agent in UserFacingAgents:
            agent.name
            agent.responsibility
            agent.expands_to
        session.selected_agent.group
        session.selected_agent.name
        session.selected_agent.mission
        session.selected_agent.inputs
        session.selected_agent.outputs
        session.selected_agent.gate
        session.selected_agent.prompt

    provides:
        UserSelectsAgent(session, agent)
            when agent in Agents
        UserCopiesAgentPrompt(session, session.selected_agent)
        AgentPromptCopyFails(session, session.selected_agent)
}

surface CycleDashboard {
    facing viewer: DashboardSession

    context session: DashboardSession

    exposes:
        session.completion_percent
        for stage in CycleStages:
            stage.label
            stage.owner
        session.selected_stage.evidence
        session.selected_stage.output

    provides:
        UserSelectsCycleStage(session, stage)
            when stage in CycleStages
        UserAdvancesCycleStage(session)
}

surface RoadmapDashboard {
    facing viewer: DashboardSession

    context session: DashboardSession

    exposes:
        for project in DojoProjects where session.project_filter = all or project.phase = session.project_filter:
            project.id
            project.title
            project.level
            project.language
            project.architecture
            project.learning_goal

    provides:
        UserFiltersRoadmap(session, all)
        UserFiltersRoadmap(session, fundamentos)
        UserFiltersRoadmap(session, concorrencia)
        UserFiltersRoadmap(session, arquitetura)
        UserFiltersRoadmap(session, escalabilidade)
        UserFiltersRoadmap(session, resiliencia)
        UserFiltersRoadmap(session, sistemas_complexos)
        UserSelectsProject(session, project)
            when project in DojoProjects
}

invariant SelectedAgentIsConfigured {
    for session in DashboardSessions:
        session.selected_agent in Agents
}

invariant SelectedStageIsConfigured {
    for session in DashboardSessions:
        session.selected_stage in CycleStages
}

invariant UnmeasuredMetricsDoNotPretendToHaveValues {
    for metric in Metrics:
        (not metric.is_measured) implies metric.measurement = null
}

invariant DashboardDistinguishesUserFacingAgentsFromTutorCore {
    UserFacingAgents.count = 10 and Agents.count = 14
}

open question "Should the current project always be the first configured project, or should it be selected from learner state?"
