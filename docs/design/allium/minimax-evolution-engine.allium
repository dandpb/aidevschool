-- allium: 3
-- minimax-evolution-engine.allium

-- Scope: Claude Code orchestration behaviour distilled from engines/miniMaxEvolutionEngine/CLAUDE.md and devschool commands.
-- Includes: five-phase pipeline, learning gate, producer/verifier separation, phase artifacts, manual continuous-operation boundary.
-- Excludes: Claude Code tool mechanics, shell syntax, cloud scheduling, model provider routing, exact command prompt text.

------------------------------------------------------------
-- Given
------------------------------------------------------------

given {
    gate: LearningGateState
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum DevschoolCommandName {
    status
    diagnose
    cycle
    spec
    implement
    review
    benchmark
    optimize
    verify
    next
    socratic
    recall
    `mnemosyne-compact`
    `cron-list`
    decide
    audit
}

------------------------------------------------------------
-- Entities and Variants
------------------------------------------------------------

entity DevschoolCommand {
    name: DevschoolCommandName
    requires_gate_clear: Boolean
}

entity LearningGateState {
    implementation_blocked: Boolean
    learner_attempt_evaluated: Boolean
}

entity PipelineCycle {
    project_path: String
    phase: spec_pending | spec_done | impl_done | review_done | benchmark_done | cycle_complete
    verifier_passed: Boolean
    retry_count: Integer

    transitions phase {
        spec_pending -> spec_done
        spec_done -> impl_done
        impl_done -> review_done
        review_done -> benchmark_done
        benchmark_done -> cycle_complete
        terminal: cycle_complete
    }
}

entity PhaseArtifact {
    cycle: PipelineCycle
    kind: spec | implementation | code_review | learning_notes | quiz | benchmark_results | evolution_report | diagnostic | deliverable
    path: String
    producer: curator | dev_go | dev_rust | dev_node | reviewer | benchmarker | optimizer | sonda
    verified: Boolean

    verification: VerificationResult with artifact = this
}

entity VerificationResult {
    artifact: PhaseArtifact
    result: pass | fail
    evidence_path: String
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    retry_limit: Integer = 3
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

rule DiagnoseMustPrecedeBlockedImplementation {
    when: DevschoolCommandInvoked(operator, command, cycle)
    requires: command.name = diagnose
    requires: gate.implementation_blocked = true

    ensures: PhaseArtifact.created(cycle: cycle, kind: diagnostic, path: default, producer: sonda, verified: false)
}

rule SpecPhaseProducesSpecArtifact {
    when: DevschoolCommandInvoked(operator, command, cycle)
    requires: command.name = spec
    requires: cycle.phase = spec_pending

    ensures: PhaseArtifact.created(cycle: cycle, kind: spec, path: default, producer: curator, verified: false)
}

rule ImplementationRequiresLearningGateClear {
    when: DevschoolCommandInvoked(operator, command, cycle)
    requires: command.name = implement
    requires: cycle.phase = spec_done
    requires: gate.implementation_blocked = false
    requires: gate.learner_attempt_evaluated = true

    ensures: PhaseArtifact.created(cycle: cycle, kind: implementation, path: default, producer: dev_go, verified: false)
    ensures: PhaseArtifact.created(cycle: cycle, kind: implementation, path: default, producer: dev_rust, verified: false)
    ensures: PhaseArtifact.created(cycle: cycle, kind: implementation, path: default, producer: dev_node, verified: false)
}

rule ReviewPhaseProducesReviewArtifacts {
    when: DevschoolCommandInvoked(operator, command, cycle)
    requires: command.name = review
    requires: cycle.phase = impl_done

    ensures: PhaseArtifact.created(cycle: cycle, kind: code_review, path: default, producer: reviewer, verified: false)
    ensures: PhaseArtifact.created(cycle: cycle, kind: learning_notes, path: default, producer: reviewer, verified: false)
    ensures: PhaseArtifact.created(cycle: cycle, kind: quiz, path: default, producer: reviewer, verified: false)
}

rule BenchmarkPhaseProducesBenchmarkArtifact {
    when: DevschoolCommandInvoked(operator, command, cycle)
    requires: command.name = benchmark
    requires: cycle.phase = review_done

    ensures: PhaseArtifact.created(cycle: cycle, kind: benchmark_results, path: default, producer: benchmarker, verified: false)
}

rule OptimizePhaseProducesEvolutionReport {
    when: DevschoolCommandInvoked(operator, command, cycle)
    requires: command.name = optimize
    requires: cycle.phase = benchmark_done

    ensures: PhaseArtifact.created(cycle: cycle, kind: evolution_report, path: default, producer: optimizer, verified: false)
}

rule VerifierPassAdvancesPhase {
    when: VerifierPublishes(result)
    requires: result.result = pass

    ensures: result.artifact.verified = true
    ensures: result.artifact.cycle.verifier_passed = true
}

rule PhaseAdvanceRequiresVerifierPass {
    when: AdvancePipeline(cycle, next_phase)
    requires: cycle.verifier_passed = true

    ensures: cycle.phase = next_phase
    ensures: cycle.verifier_passed = false
}

rule VerifierFailureKeepsPhaseOpen {
    when: VerifierPublishes(result)
    requires: result.result = fail

    ensures: result.artifact.verified = false
    ensures: result.artifact.cycle.verifier_passed = false
}

rule VerifierFailureIncrementsRetryCount {
    when: VerifierPublishes(result)
    requires: result.result = fail

    ensures: result.artifact.cycle.retry_count = result.artifact.cycle.retry_count + 1
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

invariant ImplementationDoesNotBypassLearningGate {
    for artifact in PhaseArtifacts:
        artifact.kind = implementation implies artifact.cycle.phase != spec_pending
}

invariant UnverifiedArtifactsDoNotAdvancePipeline {
    for artifact in PhaseArtifacts:
        artifact.verified = false implies artifact.cycle.verifier_passed = false
}

------------------------------------------------------------
-- Actor Declarations
------------------------------------------------------------

actor Operator {}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface DevschoolCommandSurface {
    facing operator: Operator

    context cycle: PipelineCycle

    exposes:
        cycle.project_path
        cycle.phase
        cycle.verifier_passed

    provides:
        DevschoolCommandInvoked(operator, command, cycle)
        VerifierPublishes(result)
        AdvancePipeline(cycle, next_phase)

    @guarantee ManualWorkflowBoundary
        -- The current engine is a documented manual workflow with phase commands, not a deployed daemon.
}

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

open question "Should the engine spec model each dev language artifact separately or keep a single implementation artifact kind?"
open question "When OpenClaw/Hermes event bridge exists, should it be a separate integration spec or a surface on this one?"
