{
  "name": "websocket-chat-node",
  "version": "1.0.0",
  "description": "AI DevSchool Project 05 WebSocket chat server in Node.js/TypeScript",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
