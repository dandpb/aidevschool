FROM node:18-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json* tsconfig.json ./
RUN npm install

COPY src ./src
RUN npm run build

FROM node:18-alpine
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install --only=production

COPY --from=builder /app/dist ./dist

EXPOSE 8081
CMD ["npm", "start"]
