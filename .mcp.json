{
  "mcpServers": {
    "mongodb": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "-lc",
        "exec npx -y mongodb-mcp-server --connectionString=\"$MONGODB_MCP_CONNECTION_STRING\""
      ],
      "env": {
        "MONGODB_MCP_CONNECTION_STRING": "${MONGODB_MCP_CONNECTION_STRING}"
      },
      "disabled": true,
      "alwaysAllow": [],
      "directTools": true
    },
    "context7": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "-lc",
        "exec npx -y @upstash/context7-mcp --api-key \"$CONTEXT7_API_KEY\""
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "disabled": true,
      "alwaysAllow": [],
      "directTools": true
    },
    "chrome-devtools": {
      "command": "/Users/danielbarreto/.nvm/versions/node/v20.14.0/bin/npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "disabled": false,
      "alwaysAllow": [],
      "directTools": true
    },
    "ai-memory": {
      "type": "http",
      "url": "http://127.0.0.1:49374/mcp",
      "directTools": true
    }
  }
}
