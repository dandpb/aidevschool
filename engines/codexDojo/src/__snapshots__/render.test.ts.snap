exports[`renderShell — parity oracle > renders the cycle view with partial progress 1`] = `
"
    <main class="app-shell">
      <aside class="sidebar" aria-label="Navegação principal">
        <div class="brand-block">
          <span class="brand-mark">CD</span>
          <div>
            <strong>codexDojo</strong>
            <small>agent learning lab</small>
          </div>
        </div>
        <nav class="nav-stack"><button class="nav-button " type="button" data-view="overview">Painel</button><button class="nav-button " type="button" data-view="agents">Agentes</button><button class="nav-button is-active" type="button" data-view="cycle">Ciclo</button><button class="nav-button " type="button" data-view="roadmap">Roadmap</button><button class="nav-button " type="button" data-view="project">Projeto 01</button></nav>
      </aside>
      <div class="content-shell">
        
    <section class="workbench cycle-view" aria-label="Ciclo operacional">
      <div class="section-heading">
        <p class="eyebrow">Loop contínuo</p>
        <h2>Pequenos passos, evidência antes de avanço</h2>
      </div>

      <div class="cycle-board">
        <div class="timeline">
          
                <button class="timeline-step  is-complete" type="button" data-stage="diagnosticar">
                  <span>01</span>
                  Diagnosticar nível
                </button>
              
                <button class="timeline-step  is-complete" type="button" data-stage="escolher">
                  <span>02</span>
                  Escolher conceito
                </button>
              
                <button class="timeline-step  " type="button" data-stage="projetar">
                  <span>03</span>
                  Criar mini-projeto
                </button>
              
                <button class="timeline-step  " type="button" data-stage="implementar">
                  <span>04</span>
                  Implementar versão 1
                </button>
              
                <button class="timeline-step  " type="button" data-stage="testar">
                  <span>05</span>
                  Criar testes
                </button>
              
                <button class="timeline-step  " type="button" data-stage="medir">
                  <span>06</span>
                  Rodar métricas
                </button>
              
                <button class="timeline-step is-active " type="button" data-stage="revisar">
                  <span>07</span>
                  Revisar código
                </button>
              
                <button class="timeline-step  " type="button" data-stage="refatorar">
                  <span>08</span>
                  Refatorar
                </button>
              
                <button class="timeline-step  " type="button" data-stage="comparar">
                  <span>09</span>
                  Comparar alternativa
                </button>
              
                <button class="timeline-step  " type="button" data-stage="registrar">
                  <span>10</span>
                  Registrar aprendizado
                </button>
              
        </div>

        <article class="stage-detail">
          <div class="console-header">
            <span>Revisor</span>
            <span>20% validado</span>
          </div>
          <h3>Revisar código</h3>
          <dl class="evidence-list">
            <div>
              <dt>Evidência exigida</dt>
              <dd>findings com severidade</dd>
            </div>
            <div>
              <dt>Artefato gerado</dt>
              <dd>relatório de revisão</dd>
            </div>
          </dl>
          <button class="action-button" type="button" data-action="advance-stage">Concluir etapa</button>
        </article>
      </div>
    </section>
  
      </div>
    </main>
  "
`;

exports[`renderShell — parity oracle > renders the overview view 1`] = `
"
    <main class="app-shell">
      <aside class="sidebar" aria-label="Navegação principal">
        <div class="brand-block">
          <span class="brand-mark">CD</span>
          <div>
            <strong>codexDojo</strong>
            <small>agent learning lab</small>
          </div>
        </div>
        <nav class="nav-stack"><button class="nav-button is-active" type="button" data-view="overview">Painel</button><button class="nav-button " type="button" data-view="agents">Agentes</button><button class="nav-button " type="button" data-view="cycle">Ciclo</button><button class="nav-button " type="button" data-view="roadmap">Roadmap</button><button class="nav-button " type="button" data-view="project">Projeto 01</button></nav>
      </aside>
      <div class="content-shell">
        
    <section class="overview-grid" aria-label="Painel operacional">
      <article class="command-panel">
        <p class="eyebrow">Laboratório contínuo</p>
        <h1>codexDojo</h1>
        <p class="lead">
          Um painel para conduzir uma escola prática de engenharia de software com agentes,
          projetos incrementais, revisão, testes, métricas e memória de aprendizado.
        </p>
        <div class="primary-actions">
          <button class="action-button" type="button" data-view="cycle">Avançar ciclo</button>
          <button class="action-button secondary" type="button" data-view="agents">Ver agentes</button>
        </div>
      </article>

      <article class="status-console">
        <div class="console-header">
          <span>Estado do dojo</span>
          <span>20% do ciclo</span>
        </div>
        <div class="meter" aria-label="Progresso do ciclo">
          <span style="width: 20%"></span>
        </div>
        <dl class="stat-grid">
          <div><dt>Agentes</dt><dd>10</dd></div>
          <div><dt>Etapas</dt><dd>10</dd></div>
          <div><dt>Projetos</dt><dd>10</dd></div>
        </dl>
      </article>

      <article class="topology" aria-label="Mapa visual dos agentes">
        <button class="agent-node node-1" type="button" data-agent="mentor">
                <span>Mentor</span>
              </button><button class="agent-node node-2" type="button" data-agent="curriculo">
                <span>Currículo</span>
              </button><button class="agent-node node-3" type="button" data-agent="arquiteto">
                <span>Arquiteto</span>
              </button><button class="agent-node node-4" type="button" data-agent="implementador">
                <span>Implementador</span>
              </button><button class="agent-node node-5" type="button" data-agent="revisor">
                <span>Revisor de Código</span>
              </button><button class="agent-node node-6" type="button" data-agent="testes">
                <span>Testes</span>
              </button><button class="agent-node node-7" type="button" data-agent="metricas">
                <span>Métricas</span>
              </button><button class="agent-node node-8" type="button" data-agent="devops">
                <span>DevOps</span>
              </button><button class="agent-node node-9" type="button" data-agent="pesquisador">
                <span>Pesquisador</span>
              </button><button class="agent-node node-10" type="button" data-agent="memoria">
                <span>Memória</span>
              </button>
      </article>

      <article class="next-project">
        <p class="eyebrow">Primeiro projeto prático</p>
        <h2>CLI de tarefas em Python</h2>
        <p>Separar entrada, domínio e persistência sem framework.</p>
        <ul>
          <li>comandos create/list/done</li><li>testes unitários</li><li>README de uso</li>
        </ul>
      </article>

      <article class="metric-strip">
        
              <div class="metric-item">
                <span>Tempo de execução</span>
                <strong>mediana + p95</strong>
              </div>
            
              <div class="metric-item">
                <span>Cobertura do núcleo</span>
                <strong>>=80%</strong>
              </div>
            
              <div class="metric-item">
                <span>Mutation score</span>
                <strong>60-70%</strong>
              </div>
            
              <div class="metric-item">
                <span>Complexidade ciclomática</span>
                <strong>mediana <10</strong>
              </div>
            
              <div class="metric-item">
                <span>Dependência de IA</span>
                <strong>queda por ciclo</strong>
              </div>
            
      </article>

      <article class="cycle-strip">
        
              <button class="stage-chip" type="button" data-stage="diagnosticar">
                <span>Mentor</span>
                Diagnosticar nível
              </button>
            
              <button class="stage-chip" type="button" data-stage="escolher">
                <span>Currículo</span>
                Escolher conceito
              </button>
            
              <button class="stage-chip" type="button" data-stage="projetar">
                <span>Arquiteto</span>
                Criar mini-projeto
              </button>
            
              <button class="stage-chip" type="button" data-stage="implementar">
                <span>Implementador</span>
                Implementar versão 1
              </button>
            
              <button class="stage-chip" type="button" data-stage="testar">
                <span>Testes</span>
                Criar testes
              </button>
            
              <button class="stage-chip" type="button" data-stage="medir">
                <span>Métricas</span>
                Rodar métricas
              </button>
            
      </article>
    </section>
  
      </div>
    </main>
