exports[`renderShell — parity oracle > renders the agents view showing the copied-prompt state 1`] = `
"
    <main class="app-shell">
      <aside class="sidebar" aria-label="Navegação principal">
        <div class="brand-block">
          <span class="brand-mark">CD</span>
          <div>
            <strong>codexDojo</strong>
            <small>agent learning lab</small>
          </div>
        </div>
        <nav class="nav-stack"><button class="nav-button " type="button" data-view="overview">Painel</button><button class="nav-button is-active" type="button" data-view="agents">Agentes</button><button class="nav-button " type="button" data-view="cycle">Ciclo</button><button class="nav-button " type="button" data-view="roadmap">Roadmap</button><button class="nav-button " type="button" data-view="project">Projeto 01</button></nav>
      </aside>
      <div class="content-shell">
        
    <section class="workbench agents-view" aria-label="Agentes do codexDojo">
      <div class="section-heading">
        <p class="eyebrow">Equipe multiagente</p>
        <h2>Responsabilidades claras, saídas verificáveis</h2>
      </div>

      <div class="agent-list">
        
              <button class="agent-row " type="button" data-agent="mentor">
                <span>Mentor</span>
                <small>Adapta o aprendizado ao nível atual</small>
              </button>
            
              <button class="agent-row " type="button" data-agent="curriculo">
                <span>Currículo</span>
                <small>Constrói a trilha progressiva</small>
              </button>
            
              <button class="agent-row is-active" type="button" data-agent="arquiteto">
                <span>Arquiteto</span>
                <small>Explica trade-offs e define arquitetura</small>
              </button>
            
              <button class="agent-row " type="button" data-agent="implementador">
                <span>Implementador</span>
                <small>Escreve código com boas práticas</small>
              </button>
            
              <button class="agent-row " type="button" data-agent="revisor">
                <span>Revisor de Código</span>
                <small>Revisa como engenheiro sênior</small>
              </button>
            
              <button class="agent-row " type="button" data-agent="testes">
                <span>Testes</span>
                <small>Cria testes e benchmarks</small>
              </button>
            
              <button class="agent-row " type="button" data-agent="metricas">
                <span>Métricas</span>
                <small>Mede evolução e compara soluções</small>
              </button>
            
              <button class="agent-row " type="button" data-agent="devops">
                <span>DevOps</span>
                <small>Ensina entrega e operação</small>
              </button>
            
              <button class="agent-row " type="button" data-agent="pesquisador">
                <span>Pesquisador</span>
                <small>Busca práticas e docs oficiais</small>
              </button>
            
              <button class="agent-row " type="button" data-agent="memoria">
                <span>Memória</span>
                <small>Preserva histórico e decisões</small>
              </button>
            
      </div>

      <article class="agent-detail">
        <div class="detail-topline">
          <span>strategy</span>
          <button class="icon-button" type="button" data-copy-agent="arquiteto" aria-label="Copiar prompt">
            Copiado
          </button>
        </div>
        <h3>Arquiteto</h3>
        <p>Escolher a arquitetura mais simples que testa a hipótese certa.</p>
        <div class="detail-columns">
          <div>
            <h4>Entradas</h4>
            <ul><li>requisitos</li><li>restrições</li><li>alternativas técnicas</li></ul>
          </div>
          <div>
            <h4>Saídas</h4>
            <ul><li>ADR</li><li>diagrama</li><li>contratos de módulo</li></ul>
          </div>
        </div>
        <div class="gate-box">
          <span>Gate</span>
          <p>Toda decisão registra alternativa rejeitada e motivo.</p>
        </div>
        <pre class="prompt-box"><code>Você é o Arquiteto. Compare alternativas, escolha a menor arquitetura adequada e documente trade-offs em ADRs curtos.</code></pre>
      </article>
    </section>
  
      </div>
    </main>
  "
`;

