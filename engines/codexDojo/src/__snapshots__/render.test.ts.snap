                <dl>
                  <div><dt>Linguagem</dt><dd>TypeScript</dd></div>
                  <div><dt>Arquitetura</dt><dd>Hono + Zod + service layer</dd></div>
                </dl>
              </article>
            
              <article class="project-card">
                <div class="project-meta">
                  <span>P05</span>
                  <span>Nível 3</span>
                </div>
                <h3>Autenticação e autorização</h3>
                <p>Separar identidade, sessão, permissão e auditoria.</p>
                <dl>
                  <div><dt>Linguagem</dt><dd>TypeScript</dd></div>
                  <div><dt>Arquitetura</dt><dd>auth boundary + policies explícitas</dd></div>
